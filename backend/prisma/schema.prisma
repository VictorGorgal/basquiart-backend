generator client {
  provider = "prisma-client-py"
  recursive_type_depth = -1
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())

  memberships     GroupMember[]
  posts           Post[]
  sentInvites     Invite[]      @relation("InviteSender")
  receivedInvites Invite[]   @relation("InviteReceiver")
  likes           PostLike[]
  ratings         PostRating[]
  comments        PostComment[]
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  visibility  GroupVisibility @default(PRIVATE)
  createdAt   DateTime @default(now())

  members  GroupMember[]
  posts    Post[]
  invites  Invite[]
}

model Invite {
  id        Int          @id @default(autoincrement())
  createdAt DateTime     @default(now())

  senderId   Int
  receiverId Int
  groupId    Int
  sender     User  @relation("InviteSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User  @relation("InviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  group      Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([receiverId, groupId]) // one pending invite per user per group
}

model GroupMember {
  id       Int              @id @default(autoincrement())
  role     GroupRole        @default(MEMBER)
  joinedAt DateTime         @default(now())

  userId  Int
  groupId Int
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId]) // a user can only join a group once
}

enum GroupRole {
  MEMBER
  OWNER
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
}

model Post {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  authorId Int
  groupId  Int
  author   User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  images   PostImage[]
  likes    PostLike[]
  ratings  PostRating[]
  comments PostComment[]
}

model PostImage {
  id        Int      @id @default(autoincrement())
  url       String
  createdAt DateTime @default(now())

  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostLike {
  createdAt DateTime @default(now())

  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())

  userId Int
  postId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model RatingCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  ratings PostRating[]
}

model PostRating {
  score Int  // 1-5

  userId     Int
  postId     Int
  categoryId Int
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  post       Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  category   RatingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, categoryId])
}
